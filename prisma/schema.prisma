generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([role])
  @@index([active])
}

model College {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  category         String
  location         String
  shortDescription String
  about            String
  courses          String[] @default([])
  fees             Json
  featured         Boolean  @default(false)
  thumbnailUrl     String?
  galleryUrls      String[] @default([])
  googleFormUrl    String?
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  admissionStatus  String   @default("open")

  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([admissionStatus])
}

model Consultation {
  id               String    @id @default(cuid())
  name             String
  phone            String
  email            String
  fatherOccupation String?
  dateOfBirth      DateTime?
  gender           String?
  state            String?
  city             String?
  branch           String?
  preferredCourse  String?
  message          String?
  status           String    @default("pending")
  notified         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  inquiryType      String    @default("general")
  source           String    @default("direct")

  @@index([status])
  @@index([createdAt])
  @@index([notified])
  @@index([inquiryType])
  @@index([source])
}

model Settings {
  id                  String   @id @default(cuid())
  adminEmail          String
  phone               String?
  address             String?
  whatsappUrl         String?
  facebookUrl         String?
  instagramUrl        String?
  twitterUrl          String?
  linkedinUrl         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  announcementEnabled Boolean  @default(false)
  announcementText    String?
}

model Banner {
  id          String   @id @default(cuid())
  uniqueId    String   @unique
  name        String
  link        String?
  imageUrl    String
  width       String   @default("full") // "full", "large", "medium", "small"
  message     String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([startDate])
  @@index([endDate])
  @@index([order])
}