# Database
DATABASE_URL="postgresql://efrin:root@localhost:5432/promise_india_db"

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-use-long-random-string"

# SMTP Email Configuration
# For Gmail: Use App Password (enable 2FA first)
# For development: Use Ethereal Email (https://ethereal.email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="your-email@gmail.com"

# Admin Email (receives consultation notifications)
ADMIN_EMAIL="admin@promiseindia.com"

# App URL (for production deployment)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
